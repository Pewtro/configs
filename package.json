{
  "name": "@putstack/root",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Putro",
  "description": "Root package for @putstack/* configuration packages that are also generally released standalone",
  "repository": "https://github.com/Pewtro/configs",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.4",
    "@changesets/cli": "2.31.0",
    "@putstack/eslint-config-typescript": "workspace:*",
    "@putstack/oxlint-config": "workspace:*",
    "@putstack/prettier-config": "workspace:*",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "eslint": "10.6.0",
    "lefthook": "2.1.9",
    "npm-run-all2": "9.0.2",
    "oxlint": "1.72.0",
    "prettier": "3.9.4",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint:fix": "pnpm lint --fix",
    "lint": "eslint --format stylish --max-warnings 0 --cache",
    "oxlint": "oxlint --format stylish --max-warnings 0",
    "prepare": "lefthook install",
    "release": "changeset publish",
    "stylecheck": "prettier --check .",
    "test:ci": "npm-run-all -p -l \"lint .\" \"oxlint .\" typecheck stylecheck test",
    "test:coverage": "pnpm run test --coverage",
    "test:ui": "vitest --ui --coverage",
    "test:watch": "vitest watch",
    "test": "vitest run",
    "typecheck": "tsc"
  }
}
